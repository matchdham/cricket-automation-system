# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# .env फाइल में ये values set करो
# Production में सभी values change करो!
# ============================================

# ============================================
# FLASK CONFIGURATION
# ============================================

FLASK_ENV=production
DEBUG=False
SECRET_KEY=your-secret-key-change-this-in-production
PORT=5000

# ============================================
# DATABASE CONFIGURATION
# ============================================

DATABASE_URL=sqlite:///database/cricket.db

# ============================================
# CRICKET API CONFIGURATION
# ============================================

CRICAPI_KEY=26d7de00-35e1-47a8-aea7-54b76903ba57

# ============================================
# GEMINI API CONFIGURATION
# Get from: https://aistudio.google.com/app/apikey
# ============================================

GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# FACEBOOK API CONFIGURATION
# Get from: https://developers.facebook.com/
# ============================================

FACEBOOK_TOKEN=your-facebook-page-token-here
FACEBOOK_PAGE_ID=your-facebook-page-id-here

# ============================================
# JWT CONFIGURATION
# ============================================

JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# RENDER DEPLOYMENT
# Set to True when deployed on Render
# ============================================

RENDER=False

# ============================================
# IMPORTANT NOTES
# ============================================

# 1. .env फाइल को NEVER GitHub पर push करो!
#    .gitignore में .env add है
#
# 2. Local machine पर ही .env रखो
#    Production में Render environment variables set करो
#
# 3. सभी API keys को secure रखो
#    कभी अलग से share मत करो
#
# 4. Production में सभी keys change करो
#    Default values use मत करो
#
# 5. Render पर .env की जरूरत नहीं है
#    सीधे environment variables set करो