# ============================================
# FLASK CONFIGURATION
# ============================================
FLASK_ENV=production
DEBUG=False
SECRET_KEY=your-secret-key-here-change-this-to-random-string
PORT=5000
RENDER=False

# ============================================
# CRICKET API
# ============================================
CRICAPI_KEY=26d7de00-35e1-47a8-aea7-54b76903ba57

# ============================================
# GEMINI API (AI Caption Generation)
# ============================================
GEMINI_API_KEY=AIzaSyDBICEZgdOksh2_YofTdXdf4omvzwylYTk

# ============================================
# FACEBOOK API (Auto-posting)
# ============================================
FACEBOOK_TOKEN=your-facebook-page-access-token-here
FACEBOOK_PAGE_ID=your-facebook-page-id-here

# ============================================
# JWT SECRET
# ============================================
JWT_SECRET_KEY=your-jwt-secret-key-here-change-this

# ============================================
# DATABASE
# ============================================
DATABASE_PATH=database/cricket.db

# ============================================
# UPLOADS
# ============================================
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# ============================================
# LOGGING
# ============================================
LOG_FILE=logs/app.log
LOG_LEVEL=INFO

# ============================================
# SCHEDULER
# ============================================
SCORE_UPDATE_INTERVAL=240
FACEBOOK_QUEUE_GAP_MINUTES=1

# ============================================
# IMAGE GENERATION
# ============================================
IMAGE_WIDTH=1080
IMAGE_HEIGHT=1350
IMAGE_QUALITY=85

# ============================================
# POLLINATIONS AI (Image generation)
# ============================================
POLLINATIONS_API=https://api.pollinations.ai/v1/generate

